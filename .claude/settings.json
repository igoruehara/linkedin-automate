{
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm i:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm zip:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(pnpm exec playwright:*)",
      "Bash(node scripts/audit-esteira.mjs:*)",
      "Bash(node scripts/validate-mermaid.mjs:*)",
      "Bash(node scripts/eval-spec-fidelity.mjs:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/load-context.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint && pnpm test"
          }
        ]
      }
    ]
  }
}
